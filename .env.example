# QQ 邮箱地址（机器人邮箱）
EMAIL_ADDRESS=your_bot@qq.com

# QQ 邮箱授权码（不是 QQ 密码！）
# 获取方式: QQ邮箱 → 设置 → 账户 → POP3/IMAP/SMTP服务 → 开启并获取授权码
EMAIL_PASSWORD=your_authorization_code

# 抖音 Cookie（必填）
# 获取方式: uv run f2 dy --auto-cookie chrome
DOUYIN_COOKIE=your_douyin_cookie

# B站 Cookie（可选，仅登录/大会员/受限内容需要）
# 格式示例: BILIBILI_AUTH="SESSDATA=xxxxx; bili_jct=yyyyy"
BILIBILI_AUTH=
